{
	"name": "medibridge",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev -p 4300",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"devtools": "npx @ai-sdk/devtools",
		"db:generate": "drizzle-kit generate --config=./src/lib/drizzle.config.ts",
		"db:push": "drizzle-kit push --config=./src/lib/drizzle.config.ts",
		"db:migrate": "bun db:generate && bun db:push --config=./src/lib/drizzle.config.ts",
		"db:seed": "bun run src/db/run-table-seeds.ts",
		"db:sync-hospitals": "bun run src/db/sync-hospitals.ts"
	},
